# Copy to backend.hcl (gitignored) and fill in your state bucket name, the same
# bucket the bootstrap stack created (`terraform output state_bucket` there).
# It embeds your management account ID, which is why it lives here, not in
# versions.tf. Initialize with:
#   terraform init -backend-config=backend.hcl
bucket = "refplatform-tf-state-<MGMT_ACCOUNT_ID>"
