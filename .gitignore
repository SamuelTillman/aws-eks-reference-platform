# Terraform
.terraform/
# .terraform.lock.hcl is committed on purpose (pinned provider versions +
# checksums for reproducible builds across dev and CI). See ADR-0003.
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
*.tfplan
crash.log

# Backend config: holds the account-specific state bucket name (see *.example)
backend.hcl

# Editors / OS
.vscode/
.idea/
.DS_Store

# Local blog drafts, staged here but never published to the public repo
blog/
